---
import type { CollectionEntry } from 'astro:content';
import CategoryBadge from './CategoryBadge.astro';
import MarketBadge from './MarketBadge.astro';
import FormattedDate from './FormattedDate.astro';
import { isLocked } from '../lib/gating';

interface Props {
  post: CollectionEntry<'blog'>;
  index?: number;
}
const { post, index } = Astro.props;
const { title, description, pubDate, publishedAt, thumbnail, category, readMinutes } = post.data;
const displayDate = publishedAt ?? pubDate;
const hasTime = !!publishedAt;
const num = typeof index === 'number' ? String(index + 1).padStart(2, '0') : null;
const locked = isLocked(post);
---

<article class="card group">
  <a href={`/blog/${post.slug}/`} class="flex h-full flex-col">
    {num && (
      <div class="mb-4 flex items-center justify-between gap-2">
        <span class="index-num">No. {num}</span>
        <div class="flex items-center gap-1.5">
          <MarketBadge post={post} />
          <CategoryBadge slug={category} asLink={false} />
        </div>
      </div>
    )}
    {!num && (
      <div class="mb-4 flex items-center gap-1.5">
        <MarketBadge post={post} />
        <CategoryBadge slug={category} asLink={false} />
      </div>
    )}

    {thumbnail && (
      <div class="mb-6 overflow-hidden border border-ink-700">
        <img
          src={thumbnail}
          alt={title}
          width="720"
          height="405"
          loading="lazy"
          class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
        />
      </div>
    )}

    <h3 class="headline-md mb-3 text-ink-50 transition-colors group-hover:text-gold-400">
      {locked && (
        <span
          class="mr-2 inline-block text-xs text-gold-400"
          title="구독자 전용"
          aria-label="구독자 전용 콘텐츠"
        >🔒</span>
      )}
      {title}
    </h3>
    <p class="mb-6 line-clamp-3 flex-1 text-sm leading-relaxed text-ink-200">
      {description}
    </p>

    <div class="flex items-center justify-between border-t border-ink-700 pt-4">
      <span class="flex items-baseline gap-3">
        <FormattedDate date={displayDate} withTime={hasTime} class="text-[13px] tracking-normal text-ink-100" />
      </span>
      <span class="text-gold-400 text-[10px] uppercase tracking-widest-2 opacity-0 transition-opacity group-hover:opacity-100">
        Read →
      </span>
    </div>
  </a>
</article>
