---
import { CATEGORIES, type CategorySlug } from '../consts';
import CategoryIcon from './CategoryIcon.astro';

interface Props {
  slug: CategorySlug;
  asLink?: boolean;
}
const { slug, asLink = true } = Astro.props;
const category = CATEGORIES.find((c) => c.slug === slug);
if (!category) throw new Error(`Unknown category: ${slug}`);

const Tag = asLink ? 'a' : 'span';
const href = asLink ? `/category/${category.slug}/` : undefined;
---

<Tag
  {href}
  class="inline-flex items-center gap-1.5 border px-2.5 py-1 text-[10px] font-medium uppercase tracking-widest-2 transition-opacity hover:opacity-75"
  style={`color: ${category.color}; border-color: ${category.color};`}
>
  <CategoryIcon slug={slug} size={11} />
  {category.name}
</Tag>
