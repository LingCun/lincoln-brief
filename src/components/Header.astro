---
import { CATEGORIES, SITE_TITLE } from '../consts';
import MarketTicker from './MarketTicker.astro';
import CategoryIcon from './CategoryIcon.astro';

const currentPath = Astro.url.pathname;

const today = new Date();
const dayShort = today.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase();
const monthShort = today.toLocaleDateString('en-US', { month: 'short' }).toUpperCase();
const dateNum = today.getDate();
---

<header class="theme-header sticky top-0 z-50 bg-ink-900/95 backdrop-blur">
  <!-- LIVE MARKET TICKER -->
  <MarketTicker />

  <!-- Top accent line — 카테고리 색 LOCK -->
  <div class="theme-accent-line h-[2px] w-full"></div>

  <!-- main bar — 3-column grid (date · logo · actions) -->
  <div class="border-b border-ink-600">
    <div class="container-x grid h-20 grid-cols-[1fr_auto_1fr] items-center md:h-24">
      <!-- LEFT: date meta -->
      <div class="hidden md:block">
        <div class="flex items-baseline gap-3 font-mono text-[10px] uppercase tracking-widest-2 text-ink-300">
          <span class="text-gold-400">{dayShort}</span>
          <span class="text-ink-200">{monthShort} {dateNum}</span>
          <span class="text-ink-400">·</span>
          <span class="text-gold-400">06:00 KST</span>
        </div>
        <div class="mt-1 font-mono text-[9px] uppercase tracking-widest-3 text-ink-400">
          A Daily Market Brief
        </div>
      </div>
      <div class="md:hidden"></div>

      <!-- CENTER: Logo (Option B — Monogram L + Rule + LINCOLN/BRIEF) -->
      <a
        href="/"
        class="logo justify-self-center"
        aria-label={SITE_TITLE}
      >
        <svg
          width="172"
          height="56"
          viewBox="0 0 172 56"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          class="logo-svg block h-12 w-auto md:h-14"
          aria-hidden="true"
        >
          <!-- Big L (italic serif) -->
          <text
            x="0"
            y="46"
            font-family="Italiana, Playfair Display, Georgia, serif"
            font-size="56"
            font-style="italic"
            fill="currentColor"
          >L</text>
          <!-- Vertical rule -->
          <line
            x1="42"
            y1="10"
            x2="42"
            y2="48"
            stroke="currentColor"
            stroke-width="0.8"
            opacity="0.7"
          />
          <!-- LINCOLN -->
          <text
            x="54"
            y="26"
            font-family="Playfair Display, Georgia, serif"
            font-size="14"
            font-weight="500"
            letter-spacing="3"
            fill="currentColor"
          >LINCOLN</text>
          <!-- BRIEF (smaller, ornament style) -->
          <text
            x="54"
            y="42"
            font-family="JetBrains Mono, monospace"
            font-size="9"
            letter-spacing="6"
            fill="currentColor"
            opacity="0.7"
          >— BRIEF —</text>
        </svg>
      </a>

      <!-- RIGHT: auth + subscribe + hamburger -->
      <div class="flex items-center justify-end gap-3">
        <a
          id="lb-auth-link"
          href="/login"
          class="hidden text-[10px] uppercase tracking-widest-2 text-ink-300 transition hover:text-gold-400 md:inline-flex"
        >
          로그인
        </a>
        <a href="/subscribe" class="btn-gold-solid hidden text-[10px] md:inline-flex">
          Subscribe
        </a>

        <button
          id="mobile-menu-toggle"
          aria-label="메뉴 열기"
          aria-expanded="false"
          class="inline-flex flex-col items-center justify-center gap-1.5 p-2"
        >
          <span class="block h-px w-6 bg-ink-50 transition-all duration-300"></span>
          <span class="block h-px w-6 bg-ink-50 transition-all duration-300"></span>
          <span class="block h-px w-6 bg-ink-50 transition-all duration-300"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- ============================================================
       CATEGORY STRIP — 4개 카테고리 상시 노출 (색·아이콘)
       ============================================================ -->
  <nav class="border-b border-ink-600 bg-ink-900" aria-label="카테고리">
    <div class="container-x">
      <ul class="grid grid-cols-4">
        {CATEGORIES.map((c, i) => {
          const href = `/category/${c.slug}/`;
          const isActive = currentPath.startsWith(href);
          return (
            <li class="relative">
              <a
                href={href}
                data-cat-slug={c.slug}
                class:list={[
                  'group cat-strip-link relative flex flex-col items-center gap-1.5 px-2 py-3 text-center transition-colors md:py-4',
                  'border-r border-ink-700 last:border-r-0',
                  isActive ? 'bg-ink-800/40' : 'hover:bg-ink-800/30',
                ]}
                style={`--cat-color: ${c.color};`}
              >
                <span
                  class:list={[
                    'cat-top-bar pointer-events-none absolute inset-x-0 top-0 h-[3px] transition-opacity duration-300',
                    isActive ? 'opacity-100' : 'opacity-30 group-hover:opacity-100',
                  ]}
                  style={`background: ${c.color};`}
                ></span>

                <CategoryIcon slug={c.slug} size={18} class="hidden sm:block" />

                <span class="font-mono text-[9px] uppercase tracking-widest-2 text-ink-300">
                  No.{String(i + 1).padStart(2, '0')}
                </span>

                <span
                  class="cat-strip-name font-serif text-sm italic md:text-[15px]"
                  style={isActive ? `color: ${c.color};` : 'color: #f5edd9;'}
                >
                  {c.name}
                </span>

                <span
                  class:list={[
                    'cat-bottom-indicator pointer-events-none absolute bottom-0 left-1/2 h-[2px] -translate-x-1/2 transition-all duration-300',
                    isActive ? 'w-8' : 'w-0 group-hover:w-8',
                  ]}
                  style={`background: ${c.color};`}
                ></span>
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</header>

<!-- ============================================================
     MOBILE / DESKTOP DRAWER
     ============================================================ -->
<div
  id="mobile-drawer"
  class="fixed inset-0 z-[60] hidden flex-col bg-ink-950"
  aria-hidden="true"
>
  <div class="grain pointer-events-none absolute inset-0 opacity-50"></div>

  <div class="relative flex h-20 items-center justify-between border-b border-ink-600 px-6">
    <span class="font-display text-3xl text-ink-50">Lincoln</span>
    <button
      id="mobile-menu-close"
      aria-label="메뉴 닫기"
      class="p-2 text-ink-50 hover:text-gold-400"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <nav class="relative flex-1 overflow-y-auto px-6 py-10">
    <p class="eyebrow mb-6">— Editions —</p>
    <ul class="space-y-5">
      {CATEGORIES.map((c, i) => (
        <li>
          <a
            href={`/category/${c.slug}/`}
            class="group flex items-center gap-4 border-b border-ink-700/60 py-3 transition-colors hover:bg-ink-900/40"
          >
            <span class="font-mono text-xs text-gold-500">No. {String(i + 1).padStart(2, '0')}</span>
            <CategoryIcon slug={c.slug} size={20} />
            <span
              class="font-serif text-2xl italic text-ink-50 transition-colors"
              style={`--cat-color: ${c.color};`}
            >
              {c.name}
            </span>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-12 border-t border-ink-600 pt-8">
      <p class="eyebrow mb-6">— More —</p>
      <ul class="space-y-4 text-sm text-ink-100">
        <li><a href="/blog/" class="hover:text-gold-400">전체 글</a></li>
        <li><a href="/about/" class="hover:text-gold-400">About Lincoln</a></li>
        <li><a href="/rss.xml" class="hover:text-gold-400">RSS</a></li>
      </ul>
    </div>

    <a href="#subscribe" class="btn-gold-solid mt-8 w-full justify-center text-center" id="mobile-subscribe-link">
      Subscribe
    </a>
  </nav>
</div>

<script is:inline>
  (function () {
    /* --------- Mobile Drawer --------- */
    const toggle = document.getElementById('mobile-menu-toggle');
    const close = document.getElementById('mobile-menu-close');
    const drawer = document.getElementById('mobile-drawer');
    const body = document.body;
    if (toggle && drawer) {
      const open = () => {
        drawer.classList.remove('hidden');
        drawer.classList.add('flex');
        drawer.setAttribute('aria-hidden', 'false');
        toggle.setAttribute('aria-expanded', 'true');
        body.style.overflow = 'hidden';
      };
      const shut = () => {
        drawer.classList.add('hidden');
        drawer.classList.remove('flex');
        drawer.setAttribute('aria-hidden', 'true');
        toggle.setAttribute('aria-expanded', 'false');
        body.style.overflow = '';
      };
      toggle.addEventListener('click', open);
      close?.addEventListener('click', shut);
      drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', shut));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !drawer.classList.contains('hidden')) shut();
      });
    }

    /* --------- Theme Scroll-Lock (IntersectionObserver) ---------
       각 [data-theme] 섹션이 뷰포트 중앙 20% 영역에 들어오면
       --theme-color 갱신 → 헤더·배경 라디얼이 자동 반응.
       LOCK 동작: 같은 섹션 안에서 스크롤 → 콜백 안 일어남 → 색 유지.
       NB: Header 가 body 최상단에서 렌더되므로 inline script 실행 시점엔
       아래 슬롯의 [data-theme] 섹션이 아직 없음 → DOMContentLoaded 대기.
    */
    const initThemeScrollLock = () => {
      if (!('IntersectionObserver' in window)) return;
      const root = document.documentElement;
      const DEFAULT_COLOR = '#d8b878';
      const setTheme = (slug, color) => {
        root.style.setProperty('--theme-color', color || DEFAULT_COLOR);
        if (slug) root.dataset.activeTheme = slug;
        else delete root.dataset.activeTheme;
        /* 카테고리 띠 활성 시각화 — 현재 테마 슬러그와 일치하는 탭 강조 */
        document.querySelectorAll('.cat-strip-link').forEach((el) => {
          const isMatch = el.dataset.catSlug === slug;
          el.classList.toggle('strip-active', isMatch);
        });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              const slug = el.dataset.theme || '';
              const color = el.dataset.themeColor || DEFAULT_COLOR;
              setTheme(slug, color);
            }
          });
        },
        {
          /* 뷰포트 중앙 20% 영역만 활성 존 — 한 섹션만 매칭됨 */
          rootMargin: '-40% 0px -40% 0px',
          threshold: 0,
        }
      );

      const sections = document.querySelectorAll('[data-theme]');
      sections.forEach((s) => observer.observe(s));

      /* 초기값: 첫 로드 시 default */
      setTheme('', DEFAULT_COLOR);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initThemeScrollLock);
    } else {
      initThemeScrollLock();
    }

    /* --------- Auth link toggle (client-side) --------- */
    const initAuthLink = async () => {
      const link = document.getElementById('lb-auth-link');
      if (!link) return;
      try {
        const res = await fetch('/api/auth/me', { credentials: 'same-origin' });
        if (!res.ok) return;
        const data = await res.json();
        if (data.user) {
          link.setAttribute('href', '/account');
          link.textContent = '계정';
        }
      } catch (err) {
        /* leave default "로그인" */
      }
    };
    initAuthLink();
  })();
</script>

<style>
  /* Default theme color */
  :root {
    --theme-color: #d8b878;
  }

  /* Top accent line — 카테고리 색 LOCK */
  .theme-accent-line {
    background: linear-gradient(90deg, transparent, var(--theme-color), transparent);
    opacity: 0.55;
    transition: background 0.7s ease, opacity 0.7s ease;
  }

  /* 로고 색 — 항상 골드 고정. 카테고리 진입 시 색 바뀌면 산만하다는 피드백 반영. */
  .logo {
    color: #d8b878;
  }

  /* 카테고리 띠 — 활성 (스크롤 락 매칭) */
  .cat-strip-link.strip-active {
    background-color: rgba(34, 27, 20, 0.6);
  }
  .cat-strip-link.strip-active .cat-top-bar {
    opacity: 1 !important;
    height: 4px !important;
  }
  .cat-strip-link.strip-active .cat-bottom-indicator {
    width: 32px !important;
  }
  .cat-strip-link.strip-active .cat-strip-name {
    color: var(--cat-color) !important;
  }

  /* Reduce-motion 사용자 */
  @media (prefers-reduced-motion: reduce) {
    .theme-accent-line,
    .logo,
    .cat-strip-link {
      transition: none !important;
    }
  }
</style>
