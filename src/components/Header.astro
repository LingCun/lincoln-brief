---
import { CATEGORIES, SITE_TITLE } from '../consts';
import MarketTicker from './MarketTicker.astro';

const navItems = CATEGORIES.map((c) => ({ href: `/category/${c.slug}/`, label: c.name }));
const currentPath = Astro.url.pathname;

const today = new Date();
const isoDate = today.toLocaleDateString('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<header class="sticky top-0 z-50 bg-ink-900/95 backdrop-blur">
  <!-- LIVE MARKET TICKER -->
  <MarketTicker />

  <!-- Date strip -->
  <div class="hidden border-b border-ink-700 md:block">
    <div class="container-x flex h-9 items-center justify-between text-[10px] uppercase tracking-widest-2 text-ink-200">
      <span class="font-mono text-gold-400">A DAILY MARKET BRIEF</span>
      <span class="font-mono">{isoDate}</span>
      <span class="font-mono text-gold-400">SEOUL · 06:00 KST</span>
    </div>
  </div>

  <!-- main bar -->
  <div class="border-b border-ink-600">
    <div class="container-x flex h-20 items-center justify-between gap-6">
      <a href="/" class="flex items-baseline gap-3">
        <span class="font-display text-3xl leading-none tracking-tight text-ink-50 md:text-4xl">
          Lincoln
        </span>
        <span class="hidden text-[11px] font-medium uppercase tracking-widest-3 text-gold-400 sm:inline">
          Brief
        </span>
      </a>

      <nav class="hidden lg:block">
        <ul class="flex items-center gap-8">
          {navItems.map((item) => {
            const isActive = currentPath.startsWith(item.href);
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'relative text-[11px] font-medium uppercase tracking-widest-2 transition-colors',
                    'after:absolute after:-bottom-2 after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-gold-400 after:transition-all after:duration-300',
                    'hover:after:w-full',
                    isActive ? 'text-gold-400 after:w-full' : 'text-ink-100 hover:text-gold-400',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <div class="flex items-center gap-3">
        <!-- Desktop: About + Subscribe -->
        <a
          href="/about/"
          class="hidden text-[11px] font-medium uppercase tracking-widest-2 text-ink-100 hover:text-gold-400 lg:inline"
        >
          About
        </a>
        <!--
          Search button hidden until article count > 20.
          Re-enable by removing the `hidden` class below + uncomment search-related
          mobile drawer button + SearchModal import.
        -->
        <button
          id="search-open"
          aria-label="검색"
          class="hidden p-2 text-ink-200 hover:text-gold-400 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </button>
        <a href="#subscribe" class="btn-gold-solid hidden text-[10px] md:inline-flex">
          Subscribe
        </a>

        <!-- Mobile: Hamburger -->
        <button
          id="mobile-menu-toggle"
          aria-label="메뉴 열기"
          aria-expanded="false"
          class="inline-flex flex-col items-center justify-center gap-1.5 p-2 lg:hidden"
        >
          <span class="block h-px w-6 bg-ink-50 transition-all duration-300"></span>
          <span class="block h-px w-6 bg-ink-50 transition-all duration-300"></span>
          <span class="block h-px w-6 bg-ink-50 transition-all duration-300"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- ============================================================
     MOBILE DRAWER
     ============================================================ -->
<div
  id="mobile-drawer"
  class="fixed inset-0 z-[60] hidden flex-col bg-ink-950"
  aria-hidden="true"
>
  <div class="grain pointer-events-none absolute inset-0 opacity-50"></div>

  <div class="relative flex h-20 items-center justify-between border-b border-ink-600 px-6">
    <span class="font-display text-3xl text-ink-50">Lincoln</span>
    <button
      id="mobile-menu-close"
      aria-label="메뉴 닫기"
      class="p-2 text-ink-50 hover:text-gold-400"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
  </div>

  <nav class="relative flex-1 overflow-y-auto px-6 py-10">
    <p class="eyebrow mb-6">— Editions —</p>
    <ul class="space-y-6">
      {navItems.map((item, i) => (
        <li>
          <a
            href={item.href}
            class="group flex items-baseline gap-4 text-2xl font-serif text-ink-50 hover:text-gold-400 transition-colors"
          >
            <span class="font-mono text-xs text-gold-500">No. {String(i + 1).padStart(2, '0')}</span>
            <span>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="mt-12 border-t border-ink-600 pt-8">
      <p class="eyebrow mb-6">— More —</p>
      <ul class="space-y-4 text-sm text-ink-100">
        <li><a href="/blog/" class="hover:text-gold-400">전체 글</a></li>
        <li><a href="/about/" class="hover:text-gold-400">About Lincoln</a></li>
        <li><a href="/rss.xml" class="hover:text-gold-400">RSS</a></li>
      </ul>
    </div>

    <!-- Mobile search hidden until article count > 20 -->
    <button
      id="mobile-search-open"
      class="mt-12 hidden w-full items-center gap-3 border border-ink-600 px-4 py-3 text-left text-sm text-ink-200 hover:border-gold-500 hover:text-gold-400 transition"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      검색…
    </button>

    <a href="#subscribe" class="btn-gold-solid mt-8 w-full justify-center text-center" id="mobile-subscribe-link">
      Subscribe
    </a>
  </nav>
</div>

<script is:inline>
  (function () {
    const toggle = document.getElementById('mobile-menu-toggle');
    const close = document.getElementById('mobile-menu-close');
    const drawer = document.getElementById('mobile-drawer');
    const body = document.body;
    if (!toggle || !drawer) return;

    const open = () => {
      drawer.classList.remove('hidden');
      drawer.classList.add('flex');
      drawer.setAttribute('aria-hidden', 'false');
      toggle.setAttribute('aria-expanded', 'true');
      body.style.overflow = 'hidden';
    };
    const shut = () => {
      drawer.classList.add('hidden');
      drawer.classList.remove('flex');
      drawer.setAttribute('aria-hidden', 'true');
      toggle.setAttribute('aria-expanded', 'false');
      body.style.overflow = '';
    };

    toggle.addEventListener('click', open);
    close?.addEventListener('click', shut);
    // Close when navigating internally via link in drawer
    drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', shut));
    // ESC closes
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !drawer.classList.contains('hidden')) shut();
    });
  })();
</script>
