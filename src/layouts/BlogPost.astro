---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import FormattedDate from '../components/FormattedDate.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { CATEGORIES } from '../consts';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, updatedDate, thumbnail, category, tags, readMinutes, sources } = post.data;
const catColor = CATEGORIES.find((c) => c.slug === category)?.color ?? '#d8b878';
---

<BaseLayout title={title} description={description} image={thumbnail}>
  <article
    class="relative overflow-hidden bg-ink-900"
    data-pagefind-body
    data-pagefind-meta={`category:${category}`}
    data-theme={category}
    data-theme-color={catColor}
    style={`--cat-color: ${catColor};`}
  >
    <!-- HEADER — 카테고리 테마 라디얼 워시 -->
    <header class="relative overflow-hidden border-b border-ink-600">
      <!-- Top accent line -->
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[2px]"
        style={`background: linear-gradient(90deg, transparent, ${catColor}, transparent);`}
        aria-hidden="true"
      ></div>
      <!-- Theme radial wash -->
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-full"
        style={`background: radial-gradient(ellipse 80% 70% at 50% 0%, ${catColor}28 0%, ${catColor}10 40%, transparent 80%);`}
        aria-hidden="true"
      ></div>
      <div class="container-x relative py-20 md:py-28">
        <div class="mx-auto max-w-3xl text-center">
          <div class="mb-8 flex justify-center">
            <CategoryBadge slug={category} asLink={false} />
          </div>
          <h1 class="font-serif text-4xl font-normal leading-tight tracking-tight text-ink-50 md:text-5xl lg:text-6xl">
            {title}
          </h1>
          <div
            class="mx-auto mt-8 h-px w-16"
            style={`background: ${catColor};`}
          ></div>
          <p class="mx-auto mt-8 max-w-2xl font-serif text-lg italic leading-relaxed text-ink-100 md:text-xl">
            {description}
          </p>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-4 text-ink-200">
            <FormattedDate date={pubDate} class="text-base tracking-normal text-ink-100" />
            <span class="text-gold-500 text-[10px]">◆</span>
            <span class="text-[10px] uppercase tracking-widest-2 text-ink-300">By <span class="text-gold-400">Lincoln</span></span>
            {readMinutes && (
              <>
                <span class="text-gold-500 text-[10px]">◆</span>
                <span class="font-mono text-[10px] uppercase tracking-widest-2 text-ink-300">{readMinutes} min read</span>
              </>
            )}
            {updatedDate && (
              <>
                <span class="text-gold-500 text-[10px]">◆</span>
                <span class="text-[10px] uppercase tracking-widest-2 text-ink-300">Updated <FormattedDate date={updatedDate} class="text-[10px]" /></span>
              </>
            )}
          </div>
        </div>
      </div>
    </header>

    {thumbnail && (
      <div class="border-b border-ink-600 bg-ink-950">
        <div class="container-x py-12">
          <div class="mx-auto max-w-5xl">
            <img src={thumbnail} alt={title} class="w-full border border-ink-600" />
          </div>
        </div>
      </div>
    )}

    <!-- BODY -->
    <div class="container-x py-16 md:py-24">
      <div class="prose prose-invert prose-lg mx-auto max-w-prose
                  prose-headings:font-serif prose-headings:font-medium
                  prose-h2:mt-16 prose-h2:mb-6 prose-h2:text-3xl
                  prose-h3:mt-12 prose-h3:mb-4 prose-h3:text-2xl
                  prose-p:leading-relaxed prose-p:text-ink-100
                  prose-blockquote:border-l-gold-500 prose-blockquote:font-serif prose-blockquote:italic
                  prose-strong:text-gold-400 prose-strong:font-medium
                  prose-a:text-gold-400 hover:prose-a:text-gold-300 prose-a:no-underline prose-a:border-b prose-a:border-gold-700
                  prose-table:text-sm prose-th:text-gold-400 prose-th:font-medium prose-th:uppercase prose-th:tracking-widest-2 prose-th:text-xs">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="mx-auto mt-16 max-w-prose border-t border-ink-600 pt-8">
          <p class="eyebrow mb-4">Tags</p>
          <div class="flex flex-wrap gap-3">
            {tags.map((tag) => (
              <span class="border border-ink-600 px-3 py-1 text-[10px] uppercase tracking-widest-2 text-ink-200">
                {tag}
              </span>
            ))}
          </div>
        </div>
      )}

      {sources && sources.length > 0 && (
        <div class="mx-auto mt-12 max-w-prose border-t border-ink-600 pt-8">
          <p class="eyebrow mb-4">Sources</p>
          <ul class="space-y-2 text-sm">
            {sources.map((s) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener" class="text-ink-200 hover:text-gold-400">
                  ↗ {s.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Related posts (auto: same category + tag-matched) -->
      <RelatedPosts
        currentSlug={post.slug}
        currentCategory={category}
        currentTags={tags}
      />

      <!-- Sign-off -->
      <div class="mx-auto mt-20 max-w-prose text-center">
        <div class="mx-auto h-px w-12 bg-gold-500"></div>
        <p class="mt-8 font-serif text-2xl italic text-ink-100">
          — Lincoln
        </p>
      </div>
    </div>
  </article>
</BaseLayout>
