---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import { CATEGORIES } from '../../consts';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  return CATEGORIES.map((category, idx) => {
    const posts = allPosts
      .filter((p) => p.data.category === category.slug)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
    return {
      params: { slug: category.slug },
      props: { category, posts, idx },
    };
  });
}

const { category, posts, idx } = Astro.props;
---

<BaseLayout title={category.name} description={category.description}>
  <section
    class="relative overflow-hidden bg-ink-900"
    data-theme={category.slug}
    data-theme-color={category.color}
    style={`--cat-color: ${category.color};`}
  >
    <!-- Top theme wash — 챕터 진입감 -->
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-[640px]"
      style={`background: radial-gradient(ellipse 80% 60% at 50% 0%, ${category.color}26 0%, ${category.color}10 35%, transparent 75%);`}
      aria-hidden="true"
    ></div>
    <!-- Side ambient color (very subtle) -->
    <div
      class="pointer-events-none absolute -left-32 top-40 h-[420px] w-[420px] rounded-full blur-3xl"
      style={`background: ${category.color}1f;`}
      aria-hidden="true"
    ></div>
    <div
      class="pointer-events-none absolute -right-32 top-80 h-[420px] w-[420px] rounded-full blur-3xl"
      style={`background: ${category.color}14;`}
      aria-hidden="true"
    ></div>
    <!-- Top chapter accent line -->
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-[2px]"
      style={`background: linear-gradient(90deg, transparent, ${category.color}, transparent);`}
      aria-hidden="true"
    ></div>

    <div class="container-x relative py-20 md:py-28">
      <header class="mx-auto mb-16 max-w-3xl text-center">
        <p
          class="mb-6 text-[10px] uppercase tracking-widest-3"
          style={`color: ${category.color};`}
        >— Edition No. {String(idx + 1).padStart(2, '0')} —</p>
        <div class="mb-6 flex justify-center">
          <CategoryIcon slug={category.slug} size={44} />
        </div>
        <h1
          class="font-serif text-5xl font-normal leading-tight tracking-tight md:text-6xl"
          style={`color: ${category.color};`}
        >
          {category.name}
        </h1>
        <div
          class="mx-auto mt-8 h-px w-12"
          style={`background: ${category.color};`}
        ></div>
        <p class="mx-auto mt-8 max-w-xl font-serif text-lg italic leading-relaxed text-ink-100">
          {category.description}
        </p>
        <p class="mt-6 text-sm uppercase tracking-widest-2 text-ink-300 font-mono">
          {String(posts.length).padStart(3, '0')} Issues
        </p>
      </header>

      <div
        class="mx-auto mb-16 h-px max-w-3xl"
        style={`background: linear-gradient(90deg, transparent, ${category.color}99, transparent);`}
      ></div>

      {posts.length === 0 ? (
        <div class="border border-dashed border-ink-600 p-16 text-center text-ink-300">
          이 카테고리에는 아직 글이 없습니다.
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-x-12 gap-y-16 md:grid-cols-2 lg:grid-cols-3">
          {posts.map((post, i) => <PostCard post={post} index={i} />)}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
