---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import MarketBadge from '../components/MarketBadge.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import FormattedDate from '../components/FormattedDate.astro';
import MarketSnapshot from '../components/MarketSnapshot.astro';
import { CATEGORIES, STIBEE } from '../consts';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

/* [TODO: Lincoln 검토] 마커가 본문에 남은 글은 자동 생성 초안 — 메인 노출 후보에서 제외.
   마커 제거 = 검토 완료 = 자동으로 메인 등장. */
const isReady = (p: { body: string }) => !p.body.includes('[TODO: Lincoln 검토]');

const featuredPost =
  allPosts.find((p) => p.data.featured && isReady(p)) ??
  allPosts.find(isReady) ??
  allPosts[0];
const secondaryFeatured = allPosts
  .filter((p) => p.slug !== featuredPost?.slug && isReady(p))
  .slice(0, 2);

/* 카테고리별 최신 3편 (테마 섹션용) */
const postsByCategory = CATEGORIES.map((c) => ({
  ...c,
  posts: allPosts.filter((p) => p.data.category === c.slug).slice(0, 3),
}));
---

<BaseLayout>
  <!-- ════════════════════════════════════════════════════════
       HERO — 기본 테마 (Default Gold)
       ════════════════════════════════════════════════════════ -->
  <section
    class="relative overflow-hidden border-b border-ink-600 bg-ink-900"
    data-theme=""
    data-theme-color="#d8b878"
  >
    <!-- gold radial glow -->
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-gold-500/[0.08] blur-3xl"></div>

    <!-- decorative gold chart silhouette -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.12]">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-full w-full" preserveAspectRatio="none" viewBox="0 0 1200 600">
        <polyline points="0,520 100,490 200,510 300,420 400,460 500,360 600,400 700,260 800,330 900,200 1000,260 1100,140 1200,180" fill="none" stroke="#d8b878" stroke-width="1.5"/>
        <polyline points="0,580 100,560 200,570 300,500 400,530 500,460 600,490 700,380 800,420 900,330 1000,360 1100,260 1200,290" fill="none" stroke="#d8b878" stroke-width="1" opacity="0.5"/>
        {Array.from({length: 24}).map((_, i) => {
          const x = i * 50 + 20;
          const high = 300 + Math.sin(i * 0.7) * 40;
          const low = high + 40 + Math.cos(i * 0.5) * 30;
          const open = high + 10;
          const close = low - 10;
          const isUp = close < open;
          return (
            <g opacity="0.4">
              <line x1={x} y1={high} x2={x} y2={low} stroke="#d8b878" stroke-width="0.5"/>
              <rect x={x - 4} y={isUp ? close : open} width="8" height={Math.abs(close - open)} fill="none" stroke="#d8b878" stroke-width="0.8"/>
            </g>
          );
        })}
      </svg>
    </div>
    <div class="grain pointer-events-none absolute inset-0 opacity-60"></div>

    <div class="container-x relative py-24 md:py-32">
      <div class="mx-auto max-w-5xl text-center">
        <div class="ornament mb-10">
          <span class="text-[10px] uppercase tracking-widest-3 text-gold-400">A Daily Market Brief</span>
        </div>

        <h1 class="font-display text-5xl leading-[0.95] text-ink-50 text-shadow-gold sm:text-7xl md:text-9xl lg:text-[10rem]">
          The<br/>
          <span class="italic text-gold-gradient">Lincoln</span><br/>
          Brief
        </h1>

        <div class="ornament mt-12">
          <span class="text-gold-400">◆</span>
        </div>

        <p class="mx-auto mt-12 max-w-3xl px-2 font-serif text-xl italic leading-relaxed text-ink-50 sm:text-2xl md:text-3xl">
          “수익은 타이밍에서 오고,<br/>
          <span class="text-gold-gradient">진짜 실력은 기다림에서 나옵니다.</span>”
        </p>
        <p class="mx-auto mt-8 max-w-xl text-sm leading-relaxed text-ink-200">
          미국과 한국 증시의 핵심을, 매일 아침 5분의 정제된 글로.<br/>
          시황 · 종목 · 예측 · 이슈.
        </p>

        <div class="mt-14 flex flex-wrap items-center justify-center gap-4">
          <a href="#daily-brief-section" class="btn-gold-solid">Read the Latest →</a>
          <a href="#subscribe" class="btn-ghost">Become a Member</a>
        </div>

        <div class="mx-auto mt-20 flex max-w-2xl flex-wrap items-center justify-center gap-4 border-t border-ink-600 pt-10 text-[10px] uppercase tracking-widest-2 text-ink-300 md:gap-8">
          <span class="font-mono">A Daily Market Brief</span>
          <span class="font-mono text-gold-500">◆</span>
          <span class="font-mono">발행: 매일 <span class="text-gold-400">06:00 KST</span></span>
          <span class="font-mono text-gold-500">◆</span>
          <span class="font-mono">Seoul · 2026</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════
       MARKET SNAPSHOT
       ════════════════════════════════════════════════════════ -->
  <MarketSnapshot />

  <!-- ════════════════════════════════════════════════════════
       FEATURED — Editor's Pick (기본 테마)
       ════════════════════════════════════════════════════════ -->
  {featuredPost && (
    <section
      class="border-b border-ink-600 bg-ink-900"
      data-theme=""
      data-theme-color="#d8b878"
    >
      <div class="container-x py-20 md:py-28">
        <div class="mb-12 flex items-center justify-between">
          <div class="flex items-center gap-6">
            <span class="inline-flex items-center gap-2 border border-gold-500 bg-gold-500/10 px-3 py-1 text-[10px] font-mono uppercase tracking-widest-2 text-gold-300">
              <span class="h-1.5 w-1.5 rounded-full bg-gold-400 animate-shimmer"></span>
              Editor's Pick
            </span>
            <h2 class="headline-md text-ink-50">오늘의 브리핑</h2>
          </div>
          <span class="index-num hidden md:inline">No. 01</span>
        </div>

        <div class="rule-gold-thick mb-16"></div>

        {featuredPost.data.thumbnail && (
          <a href={`/blog/${featuredPost.slug}/`} class="group mb-16 block overflow-hidden border border-ink-600 transition hover:border-gold-500">
            <img
              src={featuredPost.data.thumbnail}
              alt={featuredPost.data.title}
              class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.02]"
            />
          </a>
        )}

        <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-16">
          <div class="md:col-span-7">
            <div class="flex flex-wrap items-center gap-2">
              <MarketBadge post={featuredPost} size="md" />
              <CategoryBadge slug={featuredPost.data.category} asLink={false} />
            </div>
            <h3 class="headline-xl mt-6 text-ink-50">
              <a href={`/blog/${featuredPost.slug}/`} class="hover:text-gold-400">
                {featuredPost.data.title}
              </a>
            </h3>
            <p class="mt-8 font-serif text-xl italic leading-relaxed text-ink-100">
              {featuredPost.data.description}
            </p>
            <div class="mt-10 flex flex-wrap items-baseline gap-x-6 gap-y-2 text-ink-200">
              <FormattedDate date={featuredPost.data.publishedAt ?? featuredPost.data.pubDate} withTime={!!featuredPost.data.publishedAt} class="text-[15px] tracking-normal text-ink-100" />
              <span class="text-gold-500 text-[10px]">◆</span>
              <span class="text-[10px] uppercase tracking-widest-2">By <span class="text-gold-400">Lincoln</span></span>
            </div>
            <a href={`/blog/${featuredPost.slug}/`} class="btn-gold-solid mt-10">
              Continue Reading →
            </a>
          </div>

          <aside class="md:col-span-5 md:border-l md:border-ink-600 md:pl-16">
            <p class="eyebrow mb-8">— Also This Week —</p>
            <ul class="space-y-10">
              {secondaryFeatured.map((post, idx) => (
                <li>
                  <a href={`/blog/${post.slug}/`} class="group block">
                    <div class="mb-3 flex items-center gap-3">
                      <span class="index-num">No. {String(idx + 2).padStart(2, '0')}</span>
                      <span class="h-px flex-1 bg-ink-600 transition-all group-hover:bg-gold-500"></span>
                      <MarketBadge post={post} />
                      <CategoryBadge slug={post.data.category} asLink={false} />
                    </div>
                    <h4 class="headline-sm text-ink-50 group-hover:text-gold-400">
                      {post.data.title}
                    </h4>
                    <p class="mt-2 line-clamp-2 text-sm text-ink-200">
                      {post.data.description}
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        </div>
      </div>
    </section>
  )}

  <!-- ════════════════════════════════════════════════════════
       THE FOUR EDITIONS — 4개 테마 섹션 (스크롤 락 대상)
       ════════════════════════════════════════════════════════ -->
  {postsByCategory.map((c, idx) => (
    <section
      id={`${c.slug}-section`}
      data-theme={c.slug}
      data-theme-color={c.color}
      class="theme-section relative overflow-hidden border-b border-ink-600 bg-ink-900"
      style={`--cat-color: ${c.color};`}
    >
      <!-- 상단 액센트 라인 -->
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[2px]"
        style={`background: linear-gradient(90deg, transparent, ${c.color}, transparent);`}
        aria-hidden="true"
      ></div>
      <!-- 라디얼 워시 -->
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[640px]"
        style={`background: radial-gradient(ellipse 80% 60% at 50% 0%, ${c.color}24 0%, ${c.color}0d 35%, transparent 75%);`}
        aria-hidden="true"
      ></div>
      <!-- 사이드 앰비언트 -->
      <div
        class="pointer-events-none absolute -left-32 top-40 h-[420px] w-[420px] rounded-full blur-3xl"
        style={`background: ${c.color}1a;`}
        aria-hidden="true"
      ></div>
      <div
        class="pointer-events-none absolute -right-32 top-80 h-[420px] w-[420px] rounded-full blur-3xl"
        style={`background: ${c.color}12;`}
        aria-hidden="true"
      ></div>

      <div class="container-x relative py-24 md:py-32">
        <!-- 섹션 헤더 -->
        <header class="mx-auto mb-16 max-w-3xl text-center">
          <p
            class="mb-6 text-[10px] uppercase tracking-widest-3"
            style={`color: ${c.color};`}
          >
            — Edition No. {String(idx + 1).padStart(2, '0')} —
          </p>
          <div class="mb-6 flex justify-center">
            <CategoryIcon slug={c.slug} size={44} />
          </div>
          <h2
            class="font-serif text-5xl font-normal leading-tight tracking-tight md:text-6xl"
            style={`color: ${c.color};`}
          >
            {c.name}
          </h2>
          <div
            class="mx-auto mt-8 h-px w-12"
            style={`background: ${c.color};`}
          ></div>
          <p class="mx-auto mt-8 max-w-xl font-serif text-lg italic leading-relaxed text-ink-100">
            {c.description}
          </p>
          <p class="mt-6 text-sm uppercase tracking-widest-2 text-ink-300 font-mono">
            Latest {String(c.posts.length).padStart(2, '0')} Issues
          </p>
        </header>

        <!-- 구분선 (카테고리 색 그라데이션) -->
        <div
          class="mx-auto mb-14 h-px max-w-3xl"
          style={`background: linear-gradient(90deg, transparent, ${c.color}80, transparent);`}
        ></div>

        <!-- 최신 글 3편 -->
        {c.posts.length === 0 ? (
          <div class="border border-dashed border-ink-600 p-16 text-center text-ink-300">
            이 에디션에는 아직 글이 없습니다.
          </div>
        ) : (
          <div class="grid grid-cols-1 gap-x-12 gap-y-16 md:grid-cols-2 lg:grid-cols-3">
            {c.posts.map((post, i) => <PostCard post={post} index={i} />)}
          </div>
        )}

        <!-- 전체 보기 -->
        <div class="mt-16 text-center">
          <a
            href={`/category/${c.slug}/`}
            class="inline-flex items-center gap-3 border px-7 py-3 text-[11px] font-medium uppercase tracking-widest-2 transition hover:opacity-75"
            style={`color: ${c.color}; border-color: ${c.color};`}
          >
            {c.name} 전체 보기 →
          </a>
        </div>
      </div>
    </section>
  ))}

  <!-- ════════════════════════════════════════════════════════
       SUBSCRIBE — Members' Edition (기본 테마)
       ════════════════════════════════════════════════════════ -->
  <section
    id="subscribe"
    class="relative overflow-hidden bg-ink-950"
    data-theme=""
    data-theme-color="#d8b878"
  >
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-gold-500/[0.08] blur-3xl"></div>

    <div class="container-x relative py-24 md:py-32">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-8">— Members' Edition —</p>
        <h2 class="headline-lg text-ink-50">
          <span class="italic text-gold-gradient">정선된</span> 한 통을<br/>
          매일 아침에 받아보세요
        </h2>
        <div class="ornament mt-8">
          <span class="text-gold-400">◆</span>
        </div>
        <p class="mx-auto mt-8 max-w-md font-serif text-lg italic leading-relaxed text-ink-100">
          뉴스 30개를 읽지 않아도,<br/>
          시장 흐름이 손에 잡힙니다.
        </p>

        <div class="mx-auto mt-12 max-w-md">
          <div class="border border-gold-700/50 bg-ink-900/50 px-6 py-8 text-center">
            <p class="text-[10px] uppercase tracking-widest-3 text-gold-400">— Coming Soon —</p>
            <p class="mt-4 font-serif text-2xl italic text-ink-50">
              구독 시스템 준비 중
            </p>
            <p class="mt-4 text-sm leading-relaxed text-ink-200">
              매일 아침 6시 발행을 정식 시작하기 전까지<br/>
              뉴스레터 인프라를 준비하고 있습니다.<br/>
              곧 이메일로 받아보실 수 있게 됩니다.
            </p>
            <a href="/rss.xml" class="btn-ghost mt-8 text-[10px]">
              ↗ 우선 RSS 로 구독하기
            </a>
          </div>
          <p class="mt-6 text-center text-[10px] uppercase tracking-widest-2 text-ink-300">
            무료 · 매일 한 통 · 언제든 해지
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
