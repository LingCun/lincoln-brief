# API Keys for Lincoln Brief — copy to .env (gitignored)

# DART (전자공시시스템) — opendart.fss.or.kr 에서 발급 (빠름, 수 시간 내)
DART_API_KEY=

# KRX (한국거래소 OpenAPI) — openapi.krx.co.kr 에서 발급 (승인 약 1일)
KRX_API_KEY=

# (선택) Vercel 배포용 토큰 — vercel.com/account/tokens
VERCEL_TOKEN=

# ── Phase 2: Magic Link 인증 ────────────────────────────────────────────────

# Vercel KV (Upstash Redis) — Vercel 대시보드 > Storage > Create KV 후 자동 주입
# 로컬 개발 시엔 같은 값을 .env 에 복사
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Resend 트랜잭셔널 메일 — resend.com 에서 도메인 검증 후 API Key 발급
RESEND_API_KEY=

# 사이트 절대 URL (메일 본문의 로그인 링크 생성용)
# 로컬: http://localhost:4321  /  프로덕션: https://lincoln-brief.vercel.app
SITE_URL=http://localhost:4321

# 발신자 주소 — 도메인 검증된 주소여야 함. 미검증 시 onboarding@resend.dev 로 폴백
MAIL_FROM=Lincoln Brief <onboarding@resend.dev>
