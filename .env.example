# API Keys for Lincoln Brief — copy to .env (gitignored)

# DART (전자공시시스템) — opendart.fss.or.kr 에서 발급 (빠름, 수 시간 내)
DART_API_KEY=

# KRX (한국거래소 OpenAPI) — openapi.krx.co.kr 에서 발급 (승인 약 1일)
KRX_API_KEY=

# (선택) Vercel 배포용 토큰 — vercel.com/account/tokens
VERCEL_TOKEN=

# ── Market 데이터 알트 소스 (Yahoo deny list 회피, 1주차 검증 후 본채널 교체) ──
# 셋 다 미설정이어도 워크플로 정상 동작. 키 박는 순간 fetch-market 가 자동으로
# Yahoo 와 병렬 호출 후 snapshot.alt 에 기록, CI 로그에 [diff] 라인 출력.

# FRED — fred.stlouisfed.org/docs/api/api_key.html (즉시 발급, 분당 120 호출)
# 사용: 미국 10Y 국채 수익률 (DGS10) — Yahoo `^TNX` 대체.
FRED_API_KEY=

# Finnhub — finnhub.io 가입 후 dashboard 에서 발급 (즉시, 분당 60 호출)
# 사용: 미국 주식 (AAPL/MSFT/NVDA/TSLA 표본) — Yahoo us.top12 검증.
FINNHUB_API_KEY=

# Twelve Data — twelvedata.com 가입 (즉시, 일 800 호출)
# 사용: 미국 지수 (SPX/IXIC/DJI) + 금/원유 현물 (XAU·WTI/USD).
TWELVE_DATA_API_KEY=

# ── Phase 2: Magic Link 인증 ────────────────────────────────────────────────

# Vercel KV (Upstash Redis) — Vercel 대시보드 > Storage > Create KV 후 자동 주입
# 로컬 개발 시엔 같은 값을 .env 에 복사
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Resend 트랜잭셔널 메일 — resend.com 에서 도메인 검증 후 API Key 발급
RESEND_API_KEY=

# 사이트 절대 URL (메일 본문의 로그인 링크 생성용)
# 로컬: http://localhost:4321  /  프로덕션: https://lincoln-brief.vercel.app
SITE_URL=http://localhost:4321

# 발신자 주소 — 도메인 검증된 주소여야 함. 미검증 시 onboarding@resend.dev 로 폴백
MAIL_FROM=Lincoln Brief <onboarding@resend.dev>

# ── 외부 cron (cron-job.org) → GitHub Actions 브릿지 ────────────────────────
# GHA schedule cron 이 비신뢰적 (지연·드롭 빈발) → 외부 cron 이 /api/cron/dispatch hit →
# 우리 endpoint 가 GitHub API 로 워크플로 발사. docs/EXTERNAL_CRON_SETUP.md 참고.

# CRON_SECRET — 본인이 정한 랜덤 문자열 (32자+). cron-job.org 가 Authorization 헤더로 같은 값 전송.
CRON_SECRET=

# GH_DISPATCH_TOKEN — GitHub Fine-grained PAT.
#   Repository access: LingCun/lincoln-brief 만
#   Repository permissions → Actions: Read and write
#   github.com/settings/personal-access-tokens/new 에서 발급
GH_DISPATCH_TOKEN=
